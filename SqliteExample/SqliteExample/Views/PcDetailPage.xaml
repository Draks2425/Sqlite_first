<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SqliteExample.Views.PcDetailPage"
             Title="Szczegóły">
    <StackLayout Padding="10" Spacing="5">
        <Entry Placeholder="GPU" Text="{Binding Pc.GPU}" />
        <Entry Placeholder="CPU" Text="{Binding Pc.CPU}" />
        <Entry Placeholder="RAM" Text="{Binding Pc.RAM}" Keyboard="Numeric" />
        <Entry Placeholder="Kolor" Text="{Binding Pc.CaseColor}" />
        <Button Text="Zapisz" Clicked="OnSaveClicked" />
    </StackLayout>
</ContentPage>
